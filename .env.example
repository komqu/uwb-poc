# --- BLE Out-Of-Band channel configuration --------------------------
# These UUIDs identify the GATT service & characteristic used to exchange
# UWB session parameters between the two devices BEFORE the UWB ranging
# session starts. Both devices MUST use identical values.
#
# Use any random UUIDv4 in production. The defaults below are simple
# 16-bit shortcuts in the standard Bluetooth base UUID space so they are
# easy to spot with a BLE sniffer during development.

EXPO_PUBLIC_UWB_SERVICE_UUID=0000ffe0-0000-1000-8000-00805f9b34fb
EXPO_PUBLIC_UWB_CHARACTERISTIC_UUID=0000ffe1-0000-1000-8000-00805f9b34fb

# Pairing-code lookup timeout (ms) – how long the Controlee will scan for
# the Controller advertising the matching pairing code before giving up.
EXPO_PUBLIC_PAIRING_TIMEOUT_MS=30000
